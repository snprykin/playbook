server {
    listen {{ lighthouse_nginx_port }};
    server_name {{ lighthouse_server_name }};

    access_log {{ lighthouse_access_log }};
    error_log {{ lighthouse_error_log }};

    root {{ lighthouse_web_root }};

    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ /\. {
        deny all;
    }

    gzip on;
    gzip_comp_level 5;
    gzip_min_length 256;
    gzip_proxied any;
    gzip_vary on;
    gzip_types
        application/javascript
        application/json
        application/xml
        text/css
        text/plain
        text/xml
        image/svg+xml;
}
